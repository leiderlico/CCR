<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/juego_background">

    <!-- LOADING -->
    <ProgressBar
        android:id="@+id/rankingCargando"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

    <!-- CONTENIDO -->
    <ScrollView
        android:id="@+id/rankingContenido"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="80dp">

            <!-- FÁCIL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FÁCIL"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:paddingTop="8dp"
                android:paddingBottom="6dp"
                android:paddingLeft="4dp" />

            <LinearLayout
                android:id="@+id/tablaFacil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp" />

            <!-- MEDIO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MEDIO"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/red_logo"
                android:paddingTop="8dp"
                android:paddingBottom="6dp"
                android:paddingLeft="4dp" />

            <LinearLayout
                android:id="@+id/tablaMedio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp" />

            <!-- DIFÍCIL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DIFÍCIL"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingTop="8dp"
                android:paddingBottom="6dp"
                android:paddingLeft="4dp" />

            <LinearLayout
                android:id="@+id/tablaDificil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
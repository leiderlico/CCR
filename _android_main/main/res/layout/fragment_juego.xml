<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/juego_background">

    <!-- Capa decorativa de fondo -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/fondojuegos"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <!-- ═══════════════════════════════════════════
         PANEL VERIFICANDO
    ═══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelVerificando"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="56dp">

        <ImageView
            android:layout_width="200dp"
            android:layout_height="141dp"
            android:layout_marginBottom="1dp"
            android:contentDescription="Juego"
            android:src="@drawable/ic_juegosx2"
            android:tint="@color/red_logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trivia Bíblica"
            android:textSize="29sp"
            android:textStyle="bold"
            android:textColor="@color/trivia_titulo_text"
            android:layout_marginBottom="35dp" />

        <ProgressBar
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminateTint="#DF5555" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         PANEL REGISTRO
    ═══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/panelRegistro"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="56dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top|center_horizontal"
            android:orientation="vertical"
            android:paddingLeft="32dp"
            android:paddingTop="48dp"
            android:paddingRight="32dp"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="12dp"
                android:contentDescription="Juego"
                android:src="@drawable/ic_juegosx2"
                android:tint="@color/red_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Trivia Bíblica"
                android:textColor="@color/trivia_titulo_text"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="36dp"
                android:alpha="0.7"
                android:text="¿Cómo te llamás?"
                android:textColor="@color/juego_placeholder_text"
                android:textSize="17sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Nombre">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="textPersonName"
                    android:textColor="@color/juego_placeholder_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="36dp"
                android:hint="Apellido">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etApellido"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="textPersonName"
                    android:textColor="@color/juego_placeholder_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="56dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegistrar"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:backgroundTint="@color/primary"
                    android:text="COMENZAR"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/spinnerRegistrar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="@android:color/white"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════
         PANEL SELECCIÓN DIFICULTAD
    ═══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/panelDificultad"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="56dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingBottom="16dp"
            android:gravity="top|center_horizontal">

            <!-- Estadísticas -->
            <TextView
                android:id="@+id/tvEstadisticas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textSize="12sp"
                android:textColor="@color/juego_placeholder_text"
                android:alpha="0.6"
                android:gravity="center" />

            <!-- Logo -->
            <ImageView
                android:layout_width="120dp"
                android:layout_height="85dp"
                android:layout_marginBottom="8dp"
                android:contentDescription="Trivia"
                android:src="@drawable/ic_juegosx2"
                android:tint="@color/red_logo" />

            <!-- Bienvenida -->
            <TextView
                android:id="@+id/tvBienvenida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:gravity="center"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elige la dificultad"
                android:textSize="14sp"
                android:textColor="@color/juego_placeholder_text"
                android:alpha="0.7"
                android:layout_marginBottom="12dp" />

            <!-- Botones dificultad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:id="@+id/btnFacil"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:src="@drawable/btnfacil"
                    android:scaleType="fitXY"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Fácil" />
                <ProgressBar
                    android:id="@+id/spinnerFacil"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:indeterminateTint="@color/primary"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:id="@+id/btnMedio"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:src="@drawable/btnmedio"
                    android:scaleType="fitXY"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Medio" />
                <ProgressBar
                    android:id="@+id/spinnerMedio"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:indeterminateTint="@color/red_logo"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">
                <ImageView
                    android:id="@+id/btnDificil"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:src="@drawable/btndificil"
                    android:scaleType="fitXY"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Difícil" />
                <ProgressBar
                    android:id="@+id/spinnerDificil"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:indeterminateTint="#333333"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Línea divisoria -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/primary"
                android:alpha="0.25"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <!-- FÁCIL label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FÁCIL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/ranking_dificultad_text"
                android:layout_marginBottom="4dp" />

            <!-- FÁCIL tarjetas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_gold" android:layout_marginEnd="5dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥇" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankF1" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#5D4037" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_silver" android:layout_marginEnd="5dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥈" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankF2" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#424242" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_bronze"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥉" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankF3" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#4E342E" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- MEDIO label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MEDIO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/ranking_dificultad_text"
                android:layout_marginBottom="4dp" />

            <!-- MEDIO tarjetas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_gold" android:layout_marginEnd="5dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥇" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankM1" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#5D4037" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_silver" android:layout_marginEnd="5dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥈" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankM2" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#424242" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_bronze"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥉" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankM3" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#4E342E" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- DIFÍCIL label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DIFÍCIL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/ranking_dificultad_text"
                android:layout_marginBottom="4dp" />

            <!-- DIFÍCIL tarjetas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_gold" android:layout_marginEnd="5dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥇" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankD1" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#5D4037" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_silver" android:layout_marginEnd="5dp"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥈" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankD2" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#424242" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical"
                    android:background="@drawable/bg_medal_bronze"
                    android:paddingTop="8dp" android:paddingBottom="8dp"
                    android:paddingLeft="6dp" android:paddingRight="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥉" android:textSize="26sp" android:layout_marginEnd="2dp"/>
                    <TextView android:id="@+id/rankD3" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="start" android:textSize="10sp"
                        android:textColor="#4E342E" android:maxLines="2" android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Botón ver detalles -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerRanking"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="VER DETALLES"
                android:textSize="13sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary" />

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════
         PANEL JUEGO
    ═══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/panelJuego"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="56dp"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:id="@+id/tvContadorPreguntas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="17sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCronometro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="30.0"
                android:textSize="60sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:gravity="center"
                android:layout_marginBottom="6dp"
                android:fontFamily="monospace" />

            <ProgressBar
                android:id="@+id/barTiempo"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="60000"
                android:progress="60000"
                android:progressTint="@color/primary"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvPregunta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/juego_placeholder_text"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:lineSpacingMultiplier="1.3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpcionA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:minHeight="54dp"
                    android:textSize="15sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/primary"
                    android:textColor="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpcionB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:minHeight="54dp"
                    android:textSize="15sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/primary"
                    android:textColor="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpcionC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:minHeight="54dp"
                    android:textSize="15sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/primary"
                    android:textColor="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOpcionD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="54dp"
                    android:textSize="15sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/primary"
                    android:textColor="@color/primary" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════
         PANEL RESULTADO
    ═══════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/panelResultado"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="56dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="64dp"
            android:paddingLeft="32dp"
            android:paddingRight="32dp"
            android:paddingBottom="16dp"
            android:gravity="top|center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Terminaste!"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginBottom="4dp">
                <TextView
                    android:id="@+id/tvPuntajeFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="80sp"
                    android:textStyle="bold"
                    android:textColor="@color/red_logo" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" pts."
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/red_logo"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="puntos esta partida"
                android:textSize="16sp"
                android:textColor="@color/juego_placeholder_text"
                android:alpha="0.7"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvNuevoTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="48dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJugarOtraVez"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="JUGAR OTRA VEZ"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerRankingResultado"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="VER RANKING"
                android:textSize="15sp"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary" />

        </LinearLayout>
    </ScrollView>

    <!-- ═══════════════════════════════════════════
         PANEL CARGANDO
    ═══════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/panelCargando"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:background="#88000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">
        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary" />
    </FrameLayout>

</FrameLayout>
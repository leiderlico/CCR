<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/radio_card_inactive">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:gravity="center_vertical">

        <!-- Thumbnail de la emisora (imagen real) -->
        <ImageView
            android:id="@+id/imgEstacionItem"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:contentDescription="Imagen de la estación" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvNombreEstacionItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/radio_title"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvFrecuenciaItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/radio_subtitle"
                android:textSize="11sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Ecualizador pequeño en la fila activa -->
        <LinearLayout
            android:id="@+id/layoutEqItem"
            android:layout_width="wrap_content"
            android:layout_height="14dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:visibility="gone">

            <View android:id="@+id/eqItemBar1"
                android:layout_width="2dp" android:layout_height="6dp"
                android:layout_marginHorizontal="1dp"
                android:background="@android:color/white" />
            <View android:id="@+id/eqItemBar2"
                android:layout_width="2dp" android:layout_height="11dp"
                android:layout_marginHorizontal="1dp"
                android:background="@android:color/white" />
            <View android:id="@+id/eqItemBar3"
                android:layout_width="2dp" android:layout_height="8dp"
                android:layout_marginHorizontal="1dp"
                android:background="@android:color/white" />
            <View android:id="@+id/eqItemBar4"
                android:layout_width="2dp" android:layout_height="14dp"
                android:layout_marginHorizontal="1dp"
                android:background="@android:color/white" />
            <View android:id="@+id/eqItemBar5"
                android:layout_width="2dp" android:layout_height="7dp"
                android:layout_marginHorizontal="1dp"
                android:background="@android:color/white" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
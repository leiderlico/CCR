<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="10dp"
    app:cardMaxElevation="14dp"
    app:cardBackgroundColor="@color/grupo_card_background"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Gradiente sutil para dar profundidad al card -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card_grupo_overlay" />

    <!-- Anillos de vinilo: se dibujan desde la esquina superior derecha,
         el MaterialCardView los recorta con sus esquinas redondeadas -->
    <View
        android:id="@+id/viewVinylRings"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="20dp">

        <!-- Icono del grupo con fondo circular translucido -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">

            <View
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_icono_grupo_circle" />

            <ImageView
                android:id="@+id/ivGrupoIcono"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:contentDescription="Icono grupo" />

        </FrameLayout>

        <!-- Nombre del grupo -->
        <TextView
            android:id="@+id/tvGrupoNombreCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:textColor="@color/grupo_card_texto"
            android:textSize="17sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:lineSpacingMultiplier="1.1" />

        <!-- Flecha con fondo circular -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">

            <View
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_flecha_circle" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_video"
                app:tint="@color/grupo_card_texto"
                android:contentDescription="Entrar" />

        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
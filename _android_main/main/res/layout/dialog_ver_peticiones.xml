<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_color">

    <!-- Estado cargando -->
    <LinearLayout
        android:id="@+id/layoutCargando"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/primary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cargando peticiones..."
            android:textColor="@color/peticion_confirmacion_texto"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Estado vacío -->
    <LinearLayout
        android:id="@+id/layoutVacio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🙏"
            android:textSize="48sp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvMensajeVacio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No hay peticiones aún"
            android:textColor="@color/peticion_confirmacion_texto"
            android:gravity="center"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- Lista de peticiones — ocupa todo el espacio disponible -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPeticiones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false"
        android:visibility="gone" />


</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_mini_libros.xml
    BottomSheet mini para navegar rápidamente a otro libro desde VersiculosFragment.
    Estructura idéntica a fragment_libros: dos columnas (Antiguo / Nuevo testamento).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Handle visual + título del sheet -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="@color/toolbar_background">

        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:background="@drawable/bg_sheet_handle"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ir a un libro"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- Headers: Antiguo | Nuevo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Antiguo testamento"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/testamento_header_text"
            android:background="@color/testamento_header_background"
            android:gravity="center"
            android:paddingVertical="5dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider_color" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nuevo testamento"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/testamento_header_text"
            android:background="@color/testamento_header_background"
            android:gravity="center"
            android:paddingVertical="5dp" />

    </LinearLayout>

    <!-- Listas de libros en dos columnas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:orientation="horizontal">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMiniAntiguo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider_color" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMiniNuevo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </LinearLayout>

</LinearLayout>
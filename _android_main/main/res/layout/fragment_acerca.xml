<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo pergamino -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/pergaminodevocionalnight"
        android:scaleType="fitXY"
        android:contentDescription="Fondo" />

    <!-- Contenido scrolleable -->
    <ScrollView
        android:id="@+id/scrollAcerca"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="80dp"
            android:paddingLeft="28dp"
            android:paddingRight="28dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_launcher"
                android:scaleType="fitCenter"
                android:layout_marginBottom="16dp"
                android:contentDescription="Logo CCR" />

            <!-- Nombre app -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CCR"
                android:gravity="center"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.08"
                android:layout_marginBottom="4dp" />

            <!-- Subtítulo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Iglesia Centro Cristiano de Restauración"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="italic"
                android:textColor="#CCE8FF"
                android:layout_marginBottom="22dp" />

            <!-- Línea decorativa -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#40FFFFFF"
                android:layout_marginBottom="24dp" />

            <!-- Sección: La app -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✦  ACERCA DE LA APP  ✦"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#99CCFF"
                android:letterSpacing="0.2"
                android:layout_marginBottom="19dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CCR nació con un propósito sencillo y profundo: poner la Palabra de Dios en las manos de cada miembro de nuestra congregación, de una manera bella, accesible y siempre disponible."
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Con CCR puedes leer la Biblia en múltiples versiones, como RVA1960, RVA2015, NVI, NTV, LBLA, etc; tambien disfrutar los devocionales diarios, explorar los videos y prédicas de nuestros pastores, y mucho más que seguimos construyendo con amor para ti."
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="24dp" />

            <!-- Línea decorativa -->
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_gravity="center"
                android:background="#60FFFFFF"
                android:layout_marginBottom="24dp" />

            <!-- Sección: La iglesia -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✦  NUESTRA IGLESIA  ✦"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#99CCFF"
                android:letterSpacing="0.2"
                android:layout_marginBottom="19dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="La iglesia Centro Cristiano de Restauración es una congregación evangélica ubicada en el barrio Luis Carlos Galán, en la esquina de la Calle Ancha, en la hermosa ciudad de Cartagena de Indias."
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Somos parte del Concilio de las Asambleas de Dios, y bajo la visión y el liderazgo de nuestros pastores principales,"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="10dp" />

            <!-- Pastores -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ps. Alex Oyuela  &amp;  Ps. Rosiris Rodríguez"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold|italic"
                android:textColor="#CCE8FF"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="…la iglesia Centro Cristiano de Restauración es hoy una congregación viva, en crecimiento, con un liderazgo que cada día se multiplica para servir mejor al Señor y a su pueblo."
                android:textSize="17sp"
                android:textStyle="italic"
                android:textColor="#FFFFFF"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="24dp" />

            <!-- Línea decorativa -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#40FFFFFF"
                android:layout_marginBottom="24dp" />

            <!-- Versículo cierre -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="&quot;Lámpara es a mis pies tu palabra, y lumbrera a mi camino.&quot;"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="italic"
                android:textColor="#CCE8FF"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salmos 119:105"
                android:gravity="center"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#99CCFF"
                android:layout_marginBottom="24dp" />

            <!-- Línea decorativa final -->
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_gravity="center"
                android:background="#40FFFFFF"
                android:layout_marginBottom="16dp" />

            <!-- Versión app -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Versión 1.0"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#80FFFFFF"
                android:letterSpacing="0.1" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
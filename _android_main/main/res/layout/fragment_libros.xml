<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Contenedor del header: fondo del área de libros para que el redondeo contraste -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/surface_color">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:text="Antiguo testamento"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/testamento_header_text"
                android:background="@drawable/bg_testamento_header"
                android:gravity="center"
                android:paddingVertical="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:text="Nuevo testamento"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/testamento_header_text"
                android:background="@drawable/bg_testamento_header"
                android:gravity="center"
                android:paddingVertical="8dp" />

        </LinearLayout>

        <!-- Fila de listas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAntiguo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="80dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerNuevo"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="80dp" />

        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Cargando libros..."
        android:textSize="16sp"
        android:visibility="gone" />

</FrameLayout>
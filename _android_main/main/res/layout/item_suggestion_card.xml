<?xml version="1.0" encoding="utf-8"?>
<!--
    item_suggestion_card.xml
    Card individual de sugerencia. Se agrega dinámicamente al suggestionsContainer.
    Las nuevas cards van ABAJO de las anteriores.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Fila superior: referencia + botón cerrar este card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSuggestionReference"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnCloseCard"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Cerrar esta sugerencia"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#999999"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Texto del versículo -->
        <TextView
            android:id="@+id/tvSuggestionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="serif"
            android:textColor="#555555"
            android:textSize="13sp" />

        <!-- Botón ir al versículo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToVerse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Ir al versículo"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
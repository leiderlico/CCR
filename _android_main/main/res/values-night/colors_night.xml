<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════════════════════
         COLORES BASE — se mantienen igual en dark mode
    ══════════════════════════════════════════════════════════════════════ -->
    <color name="primary">#1AAEE8</color>
    <color name="primary_dark">#1288B8</color>
    <color name="primary_light">#6ACDE8</color>
    <color name="accent">#F5D800</color>
    <color name="red_logo">#E05555</color>          <!-- Rojo más claro — legible sobre oscuro -->
    <color name="white">#FFFFFF</color>
    <color name="black">#FF000000</color>

    <!-- ══════════════════════════════════════════════════════════════════════
         1. PANTALLA GENERAL
    ══════════════════════════════════════════════════════════════════════ -->

    <!-- 1.1 Toolbar — usa el color del pergamino anterior para contrastar -->
    <color name="toolbar_background">#0E2231</color>            <!-- Azul casi negro — contrasta con el pergamino -->
    <color name="toolbar_title_text">@color/accent</color>

    <!-- 1.2 Menú hamburger — se mantiene igual -->
    <color name="toolbar_menu_icon">@color/accent</color>
    <color name="toolbar_menu_ripple">#33F5D800</color>

    <!-- 1.2b Popup versiones -->
    <color name="toolbar_popup_background">#1E3A4A</color>      <!-- Azul muy oscuro -->
    <color name="toolbar_popup_text">@color/white</color>

    <!-- 1.3 BottomNav — mismo color que toolbar para coherencia -->
    <color name="bottom_nav_background">#0E2231</color>
    <color name="bottom_nav_indicator">@color/accent</color>
    <color name="bottom_nav_item_selected">#FFFFFF</color>
    <color name="bottom_nav_item_unselected">#FFFFFF</color>

    <!-- 1.4 FAB Micrófono -->
    <color name="mic_active_color">@color/red_logo</color>
    <color name="mic_inactive_color">#AAAAAA</color>
    <color name="mic_icon_tint">#FFFFFF</color>

    <!--
        ══════════════════════════════════════════════════════════════════════
        AGREGAR ESTOS COLORES al bloque "1.5 Radio" en res/values-night/colors.xml
        ══════════════════════════════════════════════════════════════════════
        El bloque 1.5 Radio ya existe. Reemplázalo completo por esto:
    -->

    <!-- 1.5 Radio — noche -->
    <color name="radio_background">#1C1C1E</color>             <!-- Fondo oscuro tipo iOS dark -->
    <color name="radio_title">#FFFFFF</color>                  <!-- Título blanco -->
    <color name="radio_subtitle">#98989D</color>               <!-- Subtítulo gris claro -->
    <color name="radio_fab_background">@color/primary</color>  <!-- Botón play azul cyan -->
    <color name="radio_live_text">#FF453A</color>              <!-- Texto "EN VIVO" rojo brillante -->
    <color name="radio_card_inactive">#2C2C2E</color> <!-- Tarjeta inactiva — gris oscuro -->
    <color name="radio_anuncio_background">#0D2A3A</color> <!-- Fondo anuncio — azul muy oscuro -->


    <!-- 1.6 Panel sugerencias -->
    <color name="suggestion_panel_background">#EE000000</color>
    <color name="suggestion_panel_title_text">@color/accent</color>
    <color name="suggestion_card_reference_text">@color/red_logo</color>

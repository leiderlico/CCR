<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/librosFragment">

    <fragment
        android:id="@+id/librosFragment"
        android:name="com.leiderl.CCR.ui.fragments.LibrosFragment"
        android:label="BIBLIACCR"
        tools:layout="@layout/fragment_libros">
        <action
            android:id="@+id/action_libros_to_capitulos"
            app:destination="@id/capitulosFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/capitulosFragment"
        android:name="com.leiderl.CCR.ui.fragments.CapitulosFragment"
        android:label="Capítulos"
        tools:layout="@layout/fragment_capitulos">
        <argument android:name="libroId" app:argType="integer" android:defaultValue="-1" />
        <argument android:name="libroNombre" app:argType="string" android:defaultValue="" />
        <action
            android:id="@+id/action_capitulos_to_versiculos"
            app:destination="@id/versiculosFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/versiculosFragment"
        android:name="com.leiderl.CCR.ui.fragments.VersiculosFragment"
        android:label="Versículos"
        tools:layout="@layout/fragment_versiculos">
        <argument android:name="libroId" app:argType="integer" android:defaultValue="-1" />
        <argument android:name="capitulo" app:argType="integer" android:defaultValue="1" />
        <argument android:name="versiculoHighlight" app:argType="integer" android:defaultValue="-1" />
        <action
            android:id="@+id/action_versiculos_to_videos"
            app:destination="@id/gruposSelectorFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <!-- Acción para el mini selector de libros: regresa hasta libros y abre capítulos del libro elegido -->
        <action
            android:id="@+id/action_versiculos_to_capitulos_mini"
            app:destination="@id/capitulosFragment"
            app:popUpTo="@id/librosFragment"
            app:popUpToInclusive="false"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
        <!-- Acción directa a videos con filtro: mantiene el back stack para poder volver al capítulo -->
        <action
            android:id="@+id/action_versiculos_to_videos_filtro"
            app:destination="@id/videosFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/gruposSelectorFragment"
        android:name="com.leiderl.CCR.ui.fragments.GruposSelectorFragment"
        android:label="Videos"
        tools:layout="@layout/fragment_grupos_selector">
        <action
            android:id="@+id/action_gruposSelector_to_videos"
            app:destination="@id/videosFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/videosFragment"
        android:name="com.leiderl.CCR.ui.fragments.VideosFragment"
        android:label="Videos"
        tools:layout="@layout/fragment_videos">
        <argument android:name="grupoNombre" app:argType="string" android:defaultValue="" />
        <argument android:name="filtroLibroId" app:argType="integer" android:defaultValue="-1" />
        <argument android:name="filtroCapitulo" app:argType="integer" android:defaultValue="-1" />
        <action
            android:id="@+id/action_videos_to_player"
            app:destination="@id/videoPlayerFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <fragment
        android:id="@+id/videoPlayerFragment"
        android:name="com.leiderl.CCR.ui.fragments.VideoPlayerFragment"
        android:label="Reproduciendo"
        tools:layout="@layout/fragment_video_player">
        <argument android:name="urlYoutube" app:argType="string" android:defaultValue="" />
        <argument android:name="titulo" app:argType="string" android:defaultValue="" />
        <argument android:name="predicador" app:argType="string" android:defaultValue="" />
        <argument android:name="cita" app:argType="string" android:defaultValue="" />
        <argument android:name="fecha" app:argType="string" android:defaultValue="" />
    </fragment>

    <!-- Devocional -->
    <fragment
        android:id="@+id/devocionalFragment"
        android:name="com.leiderl.CCR.ui.fragments.DevocionalFragment"
        android:label="Devocional"
        tools:layout="@layout/fragment_devocional" />

    <!-- Juego -->
    <fragment
        android:id="@+id/juegoFragment"
        android:name="com.leiderl.CCR.ui.fragments.JuegoFragment"
        android:label="Juego"
        tools:layout="@layout/fragment_juego">
        <action
            android:id="@+id/action_juegoFragment_to_rankingFragment"
            app:destination="@id/rankingFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Ranking completo -->
    <fragment
        android:id="@+id/rankingFragment"
        android:name="com.leiderl.CCR.ui.fragments.RankingFragment"
        android:label="Ranking"
        tools:layout="@layout/fragment_ranking" />

    <!-- ══════════════════════════════════════════════════════
         RADIO — navegación normal con toolbar ← Radio
    ══════════════════════════════════════════════════════ -->
    <fragment
        android:id="@+id/radioFragment"
        android:name="com.leiderl.CCR.ui.fragments.RadioFragment"
        android:label="Radio"
        tools:layout="@layout/fragment_radio" />

    <!-- Peticiones -->
    <fragment
        android:id="@+id/peticionesFragment"
        android:name="com.leiderl.CCR.ui.fragments.PeticionesFragment"
        android:label="Peticiones"
        tools:layout="@layout/dialog_peticion">
        <action
            android:id="@+id/action_peticiones_to_verPeticiones"
            app:destination="@id/verPeticionesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />
    </fragment>

    <!-- Ver peticiones — solo para autorizados -->
    <fragment
        android:id="@+id/verPeticionesFragment"
        android:name="com.leiderl.CCR.ui.fragments.VerPeticionesFragment"
        android:label="Peticiones recibidas"
        tools:layout="@layout/dialog_ver_peticiones" />

    <!-- Acerca de CCR -->
    <fragment
        android:id="@+id/acercaFragment"
        android:name="com.leiderl.CCR.ui.fragments.AcercaFragment"
        android:label="Acerca de CCR"
        tools:layout="@layout/fragment_acerca" />

</navigation>